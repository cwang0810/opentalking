# Copy to `.env` in this directory for local dev:
#   cp .env.example .env
# Vite only reads env files from apps/web/ (not the repo root).

# API base path (dev server proxies /api → backend)
# VITE_API_BASE=/api

# Max chat bubbles on screen (most recent). User=right, assistant=left.
# Omit or set 0 to show full history.
VITE_CHAT_MAX_VISIBLE=2
